# ----------------------------
# Core toggles
# ----------------------------
ENV_NAME=local
DEBUG=1
ALLOWED_HOSTS=*

# Align object storage toggle with MinIO deployment (Sprint 1)
USE_MINIO=1

# ----------------------------
# Django
# ----------------------------
DJANGO_SECRET_KEY=changeme-in-prod
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_ALLOWED_CIDRS=*

# Database (Postgres)
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppass
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Cache / queues
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# Message broker (RabbitMQ for Celery)
RABBITMQ_DEFAULT_USER=appmq
RABBITMQ_DEFAULT_PASS=apppass
RABBITMQ_HOST=rabbit
RABBITMQ_PORT=5672
CELERY_BROKER_URL=amqp://${RABBITMQ_DEFAULT_USER}:${RABBITMQ_DEFAULT_PASS}@${RABBITMQ_HOST}:${RABBITMQ_PORT}// 
CELERY_RESULT_BACKEND=${REDIS_URL}

# Object storage (MinIO, S3-compatible)
MINIO_ROOT_USER=miniouser
MINIO_ROOT_PASSWORD=miniopass123
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://${MINIO_HOST}:${MINIO_PORT}
S3_REGION=us-east-1
S3_BUCKET=app-media
S3_ACCESS_KEY_ID=${MINIO_ROOT_USER}
S3_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
S3_USE_SSL=0

# CORS / CSRF
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# Gunicorn
GUNICORN_WORKERS=3
GUNICORN_BIND=0.0.0.0:8000

# Superuser bootstrap (optional)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin123

# Health polling interval (seconds)
HEALTH_CHECK_INTERVAL=2
